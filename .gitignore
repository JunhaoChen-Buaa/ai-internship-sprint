# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*
!.env.example
!agent-backend/.env.example

# Python / LangGraph backend runtime artifacts
agent-backend/.env
agent-backend/.dca_cache/
agent-backend/run_outputs/
agent-backend/src/.langgraph_api/
agent-backend/src/__pycache__/
agent-backend/src/*.egg-info/
*.pyc

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
